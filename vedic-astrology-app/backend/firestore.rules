rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny — nothing is readable or writable unless explicitly
    // allowed below. This is the top-level security posture: adding a new
    // collection later requires a deliberate rule, not an accidental gap.
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Bookings: a user may READ ONLY their own bookings. ALL writes
    // (create/update/cancel/reschedule) happen exclusively through Cloud
    // Functions using the Admin SDK, which bypasses these rules — so the
    // "allow write: if false" here is intentional and permanent, not a
    // placeholder. This guarantees the slot-locking transaction and
    // server-side validation can never be bypassed by a direct client write.
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow write: if false;
    }

    // Slots: publicly readable (so anyone browsing can see availability
    // before signing in) but never client-writable — only the
    // createBooking/cancelBooking/rescheduleBooking/generateSlots
    // functions touch this collection.
    match /slots/{slotId} {
      allow read: if true;
      allow write: if false;
    }

    // Astrologer settings: publicly readable (needed to render "About Us"
    // consultation fee, working hours context if shown), writable only via
    // the updateAstrologerSettings Cloud Function (admin-claim gated).
    match /settings/{settingId} {
      allow read: if true;
      allow write: if false;
    }

    // Users: a user may read/update only their own profile document;
    // never another user's.
    match /users/{userId} {
      allow read, update: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }
  }
}
